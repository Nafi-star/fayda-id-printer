# Copy to .env and adjust. Must match Next.js (frontend/.env.local).

# Where Next.js is reachable from this machine (use 127.0.0.1 on Windows if localhost fails)
FRONTEND_BASE_URL=http://127.0.0.1:3000

# Same secret as frontend WORKER_CALLBACK_TOKEN
WORKER_CALLBACK_TOKEN=replace-with-shared-token

REDIS_URL=redis://localhost:6379/0

# Optional: only if you use S3/MinIO in dev
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET_INPUT=fayda-input
# S3_BUCKET_OUTPUT=fayda-output
