# Copy to .env (never commit .env).
# FRONTEND_BASE_URL + WORKER_CALLBACK_TOKEN must match frontend/.env.local

FRONTEND_BASE_URL=http://127.0.0.1:3000
WORKER_CALLBACK_TOKEN=dev-shared-token-change-me

REDIS_URL=redis://127.0.0.1:6379/0

# Postgres (same DB as Next.js — Docker maps 5433 on host)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/fayda_printer

# Optional MinIO — if set, must match frontend/.env.local S3_*
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET_INPUT=fayda-input
# S3_BUCKET_OUTPUT=fayda-output
# S3_FORCE_PATH_STYLE=true
