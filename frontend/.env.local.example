# Copy to .env.local (never commit .env.local).
# Use 127.0.0.1 on Windows to avoid IPv6 localhost issues.

# --- Postgres (Docker: docker compose up -d postgres) maps host 5433 -> container 5432
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/fayda_printer

# --- Redis (required for Convert button — Docker: docker compose up -d redis)
REDIS_URL=redis://127.0.0.1:6379/0

# --- Must match worker/.env WORKER_CALLBACK_TOKEN
WORKER_CALLBACK_TOKEN=dev-shared-token-change-me

# --- Optional: MinIO/S3 (same values on worker/.env). If omitted, files use ./storage next to repo.
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET_INPUT=fayda-input
# S3_BUCKET_OUTPUT=fayda-output
# S3_FORCE_PATH_STYLE=true
