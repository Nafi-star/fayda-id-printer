# Copy to .env.local (never commit .env.local).
# Use 127.0.0.1 on Windows to avoid IPv6 localhost issues.

# --- Postgres (Docker: docker compose up -d postgres) maps host 5433 -> container 5432
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/fayda_printer

# --- Redis (required for Convert button — Docker: docker compose up -d redis)
REDIS_URL=redis://127.0.0.1:6379/0

# --- Must match worker/.env WORKER_CALLBACK_TOKEN (dev default works if both use dev-shared-token-change-me)
WORKER_CALLBACK_TOKEN=dev-shared-token-change-me

# --- New sign-ups are "pending" until approved in /admin (except the admin email in admin-config). Set to allow open registration:
# DISABLE_ADMIN_APPROVAL=true

# --- Admins (comma-separated in ADMIN_EMAILS, or single ADMIN_EMAIL). If unset, code default in admin-config.ts is used.
# ADMIN_EMAIL=owner@yourbusiness.com
# ADMIN_EMAILS=owner@yourbusiness.com,support@yourbusiness.com

# --- Optional: MinIO/S3 (same values on worker/.env). If omitted, files use ./storage next to repo.
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET_INPUT=fayda-input
# S3_BUCKET_OUTPUT=fayda-output
# S3_FORCE_PATH_STYLE=true

# --- Public URL of this app (password reset links). On Vercel, VERCEL_URL is used if unset.
# APP_URL=https://your-domain.com

# --- Password reset (Resend is simplest for production — resend.com)
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=noreply@yourdomain.com

# --- OR Gmail (use a Google "App Password", not your normal password)
# SMTP_SERVICE=gmail
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# EMAIL_FROM=you@gmail.com

# --- OR any SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=
